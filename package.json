{
  "name": "trailmaps-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "lint": "eslint . --ext .ts,.vue",
    "test": "vitest",
    "test:style-graph": "vitest run tests/style-layer-graph.test.ts tests/stylePanelGating.test.ts tests/viewport-scale.test.ts tests/map-style-effects.test.ts tests/poster-compositions.test.ts tests/refined-themes.test.ts tests/theme-application.test.ts tests/field-layer.test.ts tests/poster-editor-elements.test.ts tests/poster-layout.test.ts tests/poster-layout-draft.test.ts",
    "test:style-browser": "playwright test tests/style-browser --reporter=line",
    "test:style": "npm run test:style-graph && npm run test:style-browser",
    "themes:capture-audit": "node scripts/capture-theme-audit.mjs",
    "themes:parity": "node scripts/capture-theme-audit.mjs --targets=docs/theme_screenshots --out=/tmp/radmaps-parity --skip-owned=1",
    "themes:golden:capture": "node scripts/capture-theme-audit.mjs --out=docs/theme_goldens --skip-owned=1",
    "themes:golden:diff": "node scripts/theme-golden-diff.mjs",
    "e2e:readiness": "node scripts/e2e-readiness.mjs",
    "atlas:pipeline": "node scripts/atlas-pipeline.mjs",
    "atlas:build-overlays": "node scripts/atlas-build-overlays.mjs",
    "atlas:print-qa": "node scripts/atlas-print-qa.mjs",
    "atlas:validate-pmtiles": "node scripts/atlas-validate-pmtiles.mjs",
    "atlas:generate-manifest": "node scripts/atlas-generate-manifest.mjs",
    "atlas:merge-manifest-artifact": "node scripts/atlas-merge-manifest-artifact.mjs",
    "atlas:terrain-plan": "node scripts/atlas-terrain-plan.mjs",
    "atlas:sync-terrain-manifest": "node scripts/atlas-sync-terrain-manifest.mjs",
    "atlas:build-contours": "node scripts/build-contour-pmtiles.mjs",
    "atlas:style-agent": "node scripts/atlas-style-agent.mjs",
    "atlas:upload-object": "node scripts/upload-atlas-object.mjs",
    "atlas:upload-pmtiles": "node scripts/upload-atlas-pmtiles.mjs",
    "atlas:publish-manifest": "node scripts/upload-atlas-object.mjs --source public/atlas/manifests/production.json --object atlas/v1/manifests/production.json --content-type application/json --verify json",
    "atlas:worker:dev": "npx wrangler dev --config workers/atlas-tiles/wrangler.jsonc",
    "atlas:worker:deploy": "npx wrangler deploy --config workers/atlas-tiles/wrangler.jsonc",
    "premade:backfill-thumbnails": "node scripts/backfill-premade-thumbnails.mjs",
    "mockups:backfill-products": "node scripts/backfill-product-mockups.mjs",
    "mockups:audit-gelato-templates": "node scripts/audit-gelato-mockup-templates.mjs",
    "print-worker:dev": "node scripts/print-worker-dev.mjs",
    "aws:render-worker:sync-secrets": "scripts/aws-render-worker-sync-secrets.sh",
    "aws:render-worker:deploy-infra": "scripts/aws-render-worker-deploy-infra.sh",
    "aws:render-worker:build": "scripts/aws-render-worker-codebuild.sh",
    "aws:render-worker:build-local": "scripts/aws-render-worker-build-push.sh",
    "gelato:draft-bypass": "cd render-worker-v4 && npx tsx scripts/gelato-draft-bypass.ts",
    "stripe:webhook-sim": "cd render-worker-v4 && npx tsx scripts/stripe-webhook-sim.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@floating-ui/dom": "^1.7.6",
    "@mapbox/search-js-core": "^1.5.1",
    "@mapbox/vector-tile": "^2.0.5",
    "@nuxt/ui": "^2.18.4",
    "@nuxtjs/supabase": "^1.3.5",
    "@stripe/stripe-js": "^9.6.0",
    "@tmcw/togeojson": "^5.8.1",
    "@types/three": "^0.184.0",
    "@xmldom/xmldom": "^0.9.10",
    "cookie": "0.7.2",
    "file-type": "^22.0.1",
    "interactjs": "^1.10.27",
    "maplibre-contour": "^0.1.0",
    "maplibre-gl": "^4.7.1",
    "nuxt": "^3.14.0",
    "pbf": "^4.0.2",
    "resend": "^4.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "three": "^0.184.0",
    "vue": "^3.5.12",
    "vue3-moveable": "^0.28.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "cookie": "0.7.2"
  },
  "devDependencies": {
    "@mapbox/tilebelt": "^2.0.3",
    "@nuxt/eslint-config": "^0.5.7",
    "@playwright/test": "^1.59.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "geojson-vt": "^4.0.3",
    "osmtogeojson": "^3.0.0-beta.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pmtiles": "^4.4.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "vt-pbf": "^3.1.3",
    "vue-tsc": "^2.1.10"
  }
}
