# Standalone queue worker env.
#
# Local development can usually avoid duplicating most of these values:
# run `npm run print-worker:dev` from the repo root and the launcher will merge
# root `.env` plus this file, with this file used only for overrides.
#
# Railway/standalone deployments still need all required values configured in
# the worker service environment.

# ─── Supabase (service role; bypasses RLS) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Direct Postgres (Phase 8 print queue consumer; SELECT ... FOR UPDATE
#     SKIP LOCKED) — point at the Supabase pooler in production. ─────────────
DATABASE_URL=postgres://postgres:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

APP_URL=https://radmaps.studio
BROWSERLESS_TOKEN=your-browserless-token
BROWSERLESS_ENDPOINT=https://production-sfo.browserless.io
BROWSERLESS_TIMEOUT_MS=60000
RENDER_TICKET_SECRET=replace-with-the-same-secret-used-by-the-nuxt-app
GELATO_API_KEY=your-gelato-api-key
GELATO_ORDER_TYPE=draft

# ─── Browser screenshot renderer ─────────────────────────────────────────────
# The final print queue captures the Nuxt /render/session page in Browserless.
# RENDER_TICKET_SECRET must match the Nuxt app so the render payload endpoint
# can validate short-lived render tickets.

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
