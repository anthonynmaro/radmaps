{
  "name": "trailmaps-render-worker-v4",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RadMaps render worker v4 — MapLibre Native + Sharp chrome compositor + content-addressable cache + Postgres job queue. See RadMaps_Render_Pipeline_Plan_v4.md.",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "tsx --env-file=.env --watch index.ts",
    "dev:queue": "tsx --env-file=.env --watch queue.ts",
    "start": "node --env-file=.env dist/index.js",
    "start:queue": "node --env-file=.env dist/queue.js",
    "build": "tsup index.ts queue.ts src/**/*.ts --format esm --target node20 --out-dir dist --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@maplibre/maplibre-gl-native": "^6.4.1",
    "@supabase/supabase-js": "^2.46.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
