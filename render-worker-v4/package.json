{
  "name": "trailmaps-render-worker-v4",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RadMaps final print queue worker — Browserless screenshot orchestration, validation, Supabase upload, and Gelato submission.",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev:queue": "tsx --env-file=.env --watch queue.ts",
    "start:queue": "node --env-file=.env dist/queue.js",
    "build": "tsup queue.ts proof-server.ts src/**/*.ts --format esm --target node20 --out-dir dist --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.1",
    "pg": "^8.11.3",
    "playwright": "1.60.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
