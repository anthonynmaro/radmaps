# ─────────────────────────────────────────────────────────────────────────────
# RadMaps — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's gitignored.
#
# Where to find each service:
#   Supabase:   https://supabase.com/dashboard/project/<your-project>/settings/api
#   Strava:     https://www.strava.com/settings/api
#   Stripe:     https://dashboard.stripe.com/developers
#   Gelato:     https://dashboard.gelato.com/settings/api
#   Mapbox:     https://account.mapbox.com/access-tokens/
#   MapTiler:   https://cloud.maptiler.com/account/keys/
#   Railway:    https://railway.app (render-worker-v4 queue service > Variables)
#   Anthropic:  https://console.anthropic.com/settings/api-keys
#   Resend:     https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# Settings > API in your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key          # "anon public" key
SUPABASE_SERVICE_KEY=your-service-role-key  # "service_role" secret key — server only
# Comma-separated immutable super-admin emails. Defaults to Anthony if unset.
ADMIN_SUPER_ADMIN_EMAILS=anthonynmaro@gmail.com
# Comma-separated emails allowed to bootstrap admin rows. Defaults to super-admins.
ADMIN_BOOTSTRAP_EMAILS=anthonynmaro@gmail.com
# Optional override for feature flag environment. If omitted, RadMaps falls
# back to VERCEL_ENV, then NODE_ENV. Valid: development, preview, production, all.
FEATURE_FLAG_ENV=development

# ─── Strava OAuth ────────────────────────────────────────────────────────────
# App registered at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to your domain (e.g. radmaps.studio)
STRAVA_CLIENT_ID=your-strava-app-client-id
STRAVA_CLIENT_SECRET=your-strava-app-client-secret
# Used to encrypt Strava access/refresh tokens at rest. Generate with:
# openssl rand -hex 32
STRAVA_TOKEN_ENCRYPTION_KEY=your-long-random-strava-token-encryption-key
# No STRAVA_REDIRECT_URI needed — derived dynamically from the request origin

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Use TEST keys locally (sk_test_...) — never use live keys in dev
# Live keys go in Vercel environment variables only
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from Stripe Dashboard > Developers > Webhooks
# Endpoint URL: https://radmaps.studio/api/orders/webhook
# Events: checkout.session.completed, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Gelato Print API ────────────────────────────────────────────────────────
# Dashboard > Settings > API Keys
GELATO_API_KEY=your-gelato-api-key
# Use draft locally/full-E2E so Gelato validates and stores the order without
# sending it to production. Production physical fulfillment should use order.
GELATO_ORDER_TYPE=draft
# Dashboard > Settings > Webhooks > Signing secret
# Webhook URL: https://radmaps.studio/api/gelato/webhook
# Events: order.status_updated, order.shipped, order.delivered
GELATO_WEBHOOK_SECRET=your-gelato-webhook-signing-secret

# ─── Mapbox (topographic tiles + terrain + hillshade) ────────────────────────
# Requires scopes: styles:read, tiles:read, fonts:read
MAPBOX_TOKEN=pk.eyJ1...

# ─── MapTiler (basemap tiles) ────────────────────────────────────────────────
# Free tier: 100k tile loads/month
MAPTILER_TOKEN=your-maptiler-api-key

# ─── Stadia Maps (Stamen Watercolor/Toner raster tiles) ─────────────────────
# Used by browser previews and render workers for Stadia/Stamen presets.
# Tile URLs are visible in the browser, so restrict this key by domain in Stadia:
# radmaps.studio, Vercel preview domains, localhost/ngrok as needed for testing.
STADIA_API_KEY=your-stadia-api-key
# Optional explicit public alias; if omitted, Nuxt falls back to STADIA_API_KEY.
NUXT_PUBLIC_STADIA_API_KEY=your-stadia-api-key

# ─── RadMaps Atlas PMTiles Storage ───────────────────────────────────────────
# Public immutable manifest and PMTiles archives used by internal atlas lab and
# future owned map presets. Production artifacts live in Cloudflare R2.
NUXT_PUBLIC_RADMAPS_ATLAS_MANIFEST_URL=https://pub-your-prod-bucket.r2.dev/atlas/v1/manifests/production.json
# Direct PMTiles URLs are retained as local/fallback overrides.
NUXT_PUBLIC_RADMAPS_ATLAS_PMTILES_URL=https://pub-your-prod-bucket.r2.dev/atlas/v1/base/driftless/2026-05-15/radmaps-driftless-planetiler.pmtiles
NUXT_PUBLIC_RADMAPS_CONTOUR_PMTILES_URL=https://pub-your-prod-bucket.r2.dev/atlas/v1/terrain/driftless/2026-05-15/radmaps-driftless-contours.pmtiles
ATLAS_STORAGE_BUCKET=radmaps-atlas-prod
ATLAS_STORAGE_OBJECT_PATH=atlas/v1/base/driftless/2026-05-15/radmaps-driftless-planetiler.pmtiles
ATLAS_PUBLIC_BASE_URL=https://pub-your-prod-bucket.r2.dev
ATLAS_MIN_FREE_GB=500
PLANETILER_IMAGE=ghcr.io/onthegomap/planetiler:latest
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional. Required only when using temporary Cloudflare R2 credentials.
R2_SESSION_TOKEN=your-temporary-r2-session-token

# ─── Browser Screenshot Rendering ────────────────────────────────────────────
# Screenshot service that captures the real Nuxt render pages for proof,
# premade thumbnail, share, dashboard, and checkout previews. Production can
# point this at the AWS proof renderer App Runner URL.
# Generate it with: openssl rand -hex 32
BROWSERLESS_TOKEN=your-browserless-token
BROWSERLESS_ENDPOINT=https://production-sfo.browserless.io
BROWSERLESS_TIMEOUT_MS=60000
# AWS proof renderer allowlist. CloudFormation sets this to APP_URL by default.
PROOF_RENDER_ALLOWED_ORIGINS=https://radmaps.studio
# Final queue worker backend: browserless or local-chromium.
# AWS ECS/Fargate worker deployments should use local-chromium.
RENDER_BACKEND=browserless
RENDER_TIMEOUT_MS=60000
RENDER_TICKET_SECRET=your-long-random-render-ticket-secret
NUXT_PUBLIC_SITE_URL=http://localhost:3001

# Required for local full E2E final-print queue runs. Use the Supabase pooler.
DATABASE_URL=postgres://postgres:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Anthropic (AI Styling Agent) ────────────────────────────────────────────
# Required for /api/agent/style — optional if not using the AI assistant
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Used for order confirmation emails
# Add and verify domain at https://resend.com/domains
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@yourdomain.com

# ─── Trailforks (optional) ───────────────────────────────────────────────────
# Not yet in active use — leave blank
TRAILFORKS_API_KEY=
