# ─── Site URL (used in auth email redirect links) ──────────────
# Production: https://radmaps.studio  |  Local dev: http://localhost:3000
NUXT_PUBLIC_SITE_URL=https://radmaps.studio

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Strava OAuth ──────────────────────────────────────────────
# Register this exact URI in your Strava App settings at https://www.strava.com/settings/api
# Production:  https://radmaps.studio/api/strava/callback
# Local dev:   http://localhost:3000/api/strava/callback
STRAVA_CLIENT_ID=your-strava-app-client-id
STRAVA_CLIENT_SECRET=your-strava-app-client-secret
STRAVA_REDIRECT_URI=https://radmaps.studio/api/strava/callback

# ─── Trailforks ────────────────────────────────────────────────
TRAILFORKS_API_KEY=your-trailforks-api-key

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Gelato Print API ──────────────────────────────────────────
# Get key at https://dashboard.gelato.com/settings/api
GELATO_API_KEY=               # Your Gelato API key
GELATO_WEBHOOK_SECRET=        # From Gelato Dashboard > Settings > Webhooks > Signing secret

# ─── Anthropic (AI Styling Agent) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (Transactional Email) ──────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@yourdomain.com

# ─── Mapbox (Topographic tiles) ────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ─── MapTiler (basemap tiles — outdoor, topo, winter) ──────────
# Free tier: 100k tile loads/month — https://cloud.maptiler.com
MAPTILER_TOKEN=your-maptiler-api-key

# ─── Render Worker (Railway service) ───────────────────────────
RENDER_WORKER_URL=https://your-worker.railway.app
RENDER_WORKER_SECRET=a-long-random-secret-string
