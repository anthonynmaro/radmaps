PORT=3001
RENDER_WORKER_SECRET=a-long-random-secret-shared-with-nuxt-app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Stadia Maps API key — required for authenticated tile requests in production.
# Without this, the worker falls back to domain-based auth via the Referer header
# (APP_URL must then match an allowlisted domain in your Stadia Maps dashboard).
STADIA_API_KEY=

# URL of the Nuxt app — used as the HTTP Referer header for Stadia tile requests
# when STADIA_API_KEY is not set. Must match an allowlisted domain in Stadia Maps.
APP_URL=https://radmaps.studio
