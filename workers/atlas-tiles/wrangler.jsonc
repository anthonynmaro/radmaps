{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "radmaps-atlas-tiles",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "ATLAS_STAGING",
      "bucket_name": "radmaps-atlas-staging"
    },
    {
      "binding": "ATLAS_PROD",
      "bucket_name": "radmaps-atlas-prod"
    }
  ]
}
